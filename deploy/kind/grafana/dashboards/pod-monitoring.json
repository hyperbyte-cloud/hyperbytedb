      "title": "Total Pods",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(kube_pod_info{namespace=~\"$namespace\"})",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
